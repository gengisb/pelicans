<svg
  id="pelican-bike-scene"
  xmlns="http://www.w3.org/2000/svg"
  width="512"
  height="512"
  viewBox="0 0 512 512"
  role="img"
  aria-labelledby="title desc"
>
  <title id="title">Pelican riding a bicycle</title>
  <desc id="desc">A cartoon pelican riding a bicycle, scaled to a 512 by 512 viewBox.</desc>

  <defs id="defs-main">
    <linearGradient id="grad-sky" x1="0" y1="0" x2="0" y2="1">
      <stop id="grad-sky-stop-1" offset="0%" stop-color="#dff3ff"/>
      <stop id="grad-sky-stop-2" offset="100%" stop-color="#ffffff"/>
    </linearGradient>

    <filter id="fx-shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow id="fx-shadow-drop" dx="0" dy="2" stdDeviation="2" flood-opacity="0.15"/>
    </filter>
  </defs>

  <!-- Background -->
  <g id="layer-background">
    <rect id="bg-sky" x="0" y="0" width="512" height="512" fill="url(#grad-sky)"/>
    <ellipse id="bg-ground-shadow" cx="256" cy="440" rx="205" ry="16" fill="#e9eef2"/>
    <line id="ground-line" x1="50" y1="440" x2="462" y2="440" stroke="#cfd8df" stroke-width="3" stroke-linecap="round"/>
  </g>

  <!-- Bicycle -->
  <g
    id="bike"
    filter="url(#fx-shadow)"
    stroke="#2f3b45"
    stroke-width="4"
    fill="none"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <!-- Wheels -->
    <g id="bike-wheels">
      <circle id="wheel-rear" cx="160" cy="370" r="54"/>
      <circle id="wheel-front" cx="333" cy="370" r="54"/>
    </g>

    <!-- Spokes -->
    <g id="bike-spokes" stroke="#6c7a86" stroke-width="1.5">
      <g id="bike-spokes-rear">
        <line id="rear-spoke-1" x1="160" y1="370" x2="160" y2="316"/>
        <line id="rear-spoke-2" x1="160" y1="370" x2="198" y2="332"/>
        <line id="rear-spoke-3" x1="160" y1="370" x2="214" y2="370"/>
        <line id="rear-spoke-4" x1="160" y1="370" x2="198" y2="408"/>
        <line id="rear-spoke-5" x1="160" y1="370" x2="160" y2="424"/>
        <line id="rear-spoke-6" x1="160" y1="370" x2="122" y2="408"/>
        <line id="rear-spoke-7" x1="160" y1="370" x2="106" y2="370"/>
        <line id="rear-spoke-8" x1="160" y1="370" x2="122" y2="332"/>
      </g>
      <g id="bike-spokes-front">
        <line id="front-spoke-1" x1="333" y1="370" x2="333" y2="316"/>
        <line id="front-spoke-2" x1="333" y1="370" x2="371" y2="332"/>
        <line id="front-spoke-3" x1="333" y1="370" x2="387" y2="370"/>
        <line id="front-spoke-4" x1="333" y1="370" x2="371" y2="408"/>
        <line id="front-spoke-5" x1="333" y1="370" x2="333" y2="424"/>
        <line id="front-spoke-6" x1="333" y1="370" x2="295" y2="408"/>
        <line id="front-spoke-7" x1="333" y1="370" x2="279" y2="370"/>
        <line id="front-spoke-8" x1="333" y1="370" x2="295" y2="332"/>
      </g>
    </g>

    <!-- Frame -->
    <g id="bike-frame">
      <line id="frame-chainstay" x1="160" y1="370" x2="230" y2="319"/>
      <line id="frame-seatstay" x1="230" y1="319" x2="275" y2="370"/>
      <line id="frame-chainline" x1="275" y1="370" x2="160" y2="370"/>
      <line id="frame-top-tube" x1="230" y1="319" x2="282" y2="306"/>
      <line id="frame-down-tube" x1="282" y1="306" x2="333" y2="370"/>
      <line id="frame-front-link" x1="275" y1="370" x2="333" y2="370"/>
    </g>

    <!-- Fork + Handlebar -->
    <g id="bike-cockpit">
      <line id="fork-steerer" x1="282" y1="306" x2="292" y2="280"/>
      <line id="handlebar-main" x1="276" y1="273" x2="314" y2="270"/>
      <line id="stem" x1="292" y1="280" x2="276" y2="273"/>
    </g>

    <!-- Seat -->
    <g id="bike-seat-group">
      <line id="seatpost" x1="230" y1="319" x2="221" y2="290"/>
      <line id="saddle" x1="208" y1="287" x2="231" y2="287"/>
      <circle id="seat-contact-bolt" cx="221" cy="290" r="3" fill="#2f3b45" stroke="none"/>
    </g>

    <!-- Crank / Pedals -->
    <g id="bike-drivetrain">
      <circle id="crank-hub" cx="275" cy="370" r="8" fill="#2f3b45"/>
      <line id="crank-arm-front" x1="275" y1="370" x2="293" y2="358"/>
      <line id="pedal-link-front" x1="293" y1="358" x2="304" y2="361"/>
      <line id="crank-arm-rear" x1="275" y1="370" x2="258" y2="382"/>
      <line id="pedal-link-rear" x1="258" y1="382" x2="247" y2="385"/>
    </g>
  </g>

  <!-- Pelican -->
  <g id="pelican" filter="url(#fx-shadow)">
    <!-- Tail -->
    <path
      id="pelican-tail"
      d="M190 300 C171 294, 164 275, 180 272 C199 268, 212 282, 209 297 Z"
      fill="#8a8f98"
      stroke="#4b5560"
      stroke-width="2"
    />

    <!-- Body -->
    <ellipse id="pelican-body" cx="236" cy="297" rx="54" ry="35" fill="#f7f7f2" stroke="#4b5560" stroke-width="2"/>

    <!-- Wing -->
    <path
      id="pelican-wing"
      d="M220 288 C239 272, 274 278, 279 301 C261 314, 233 315, 216 298 Z"
      fill="#aeb5bf"
      stroke="#4b5560"
      stroke-width="2"
    />

    <!-- Neck -->
    <path
      id="pelican-neck"
      d="M267 277 C276 251, 303 242, 320 253 C306 260, 296 269, 289 284 Z"
      fill="#f7f7f2"
      stroke="#4b5560"
      stroke-width="2"
    />

    <!-- Head -->
    <circle id="pelican-head" cx="333" cy="255" r="18" fill="#f7f7f2" stroke="#4b5560" stroke-width="2"/>

    <!-- Eye -->
    <g id="pelican-eye">
      <circle id="pelican-eye-pupil" cx="338" cy="251" r="2.5" fill="#1f2937"/>
      <circle id="pelican-eye-highlight" cx="339.2" cy="249.8" r="0.8" fill="#ffffff"/>
    </g>

    <!-- Beak -->
    <g id="pelican-beak">
      <path
        id="pelican-beak-upper"
        d="M346 259 C375 254, 404 256, 428 268 C404 272, 376 273, 347 269 Z"
        fill="#f2b04c"
        stroke="#4b5560"
        stroke-width="2"
      />
      <path
        id="pelican-beak-lower-pouch"
        d="M347 269 C378 279, 398 284, 417 296 C387 298, 364 291, 343 277 Z"
        fill="#f7c98b"
        stroke="#4b5560"
        stroke-width="2"
      />
    </g>

    <!-- Helmet -->
    <g id="pelican-helmet">
      <path
        id="pelican-helmet-shell"
        d="M316 245 C322 230, 342 226, 353 238 L352 245 Z"
        fill="#ef4444"
        stroke="#4b5560"
        stroke-width="2"
      />
      <line id="pelican-helmet-rim" x1="324" y1="245" x2="351" y2="245" stroke="#4b5560" stroke-width="2"/>
    </g>

    <!-- Legs -->
    <g id="pelican-legs" stroke="#4b5560" stroke-width="3" stroke-linecap="round" fill="none">
      <path id="pelican-leg-rear" d="M223 324 L249 346 L258 382"/>
      <path id="pelican-leg-front" d="M256 324 L279 343 L293 358"/>
    </g>

    <!-- Feet -->
    <g id="pelican-feet" fill="#f2b04c" stroke="#4b5560" stroke-width="1.5">
      <path id="pelican-foot-rear" d="M254 381 l9 4 l-6 5 l-8 -3 z"/>
      <path id="pelican-foot-front" d="M289 357 l9 4 l-5 5 l-8 -3 z"/>
    </g>

    <!-- Wing/arm holding handlebar -->
    <g id="pelican-arm">
      <path
        id="pelican-arm-upper"
        d="M274 295 C286 286, 293 281, 302 277"
        stroke="#4b5560"
        stroke-width="3"
        fill="none"
        stroke-linecap="round"
      />
      <path
        id="pelican-arm-lower"
        d="M300 276 C309 271, 316 269, 323 270"
        stroke="#4b5560"
        stroke-width="2.5"
        fill="none"
        stroke-linecap="round"
      />
    </g>

    <!-- Belly/seat contour -->
    <path
      id="pelican-belly-contour"
      d="M205 316 C222 306, 248 305, 267 312"
      stroke="#d1d5db"
      stroke-width="2"
      fill="none"
    />
  </g>

  <!-- Motion accents -->
  <g id="motion-accents" stroke="#9ca3af" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.7">
    <path id="motion-rear-1" d="M95 335 q-12 5 -19 0"/>
    <path id="motion-rear-2" d="M92 351 q-9 4 -16 0"/>
    <path id="motion-front-1" d="M397 335 q12 5 19 0"/>
    <path id="motion-front-2" d="M400 351 q9 4 16 0"/>
  </g>
</svg>
